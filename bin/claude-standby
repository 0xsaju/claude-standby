#!/usr/bin/env bash
# claude-standby — survive Claude Code usage limits: wait for the reset,
# then resume the same conversation. Zero tokens; runs even while you're limited.
#
# Usage:  claude-standby <command> [options]          (tip: alias cs=…)
#
# After you hit a limit (run from your project directory):
#   resume-at reset                  resume at your 5-hour reset — exact, no probe
#   resume-at auto                   arm & watch: resume whenever a limit hits
#   resume-at 20:00 | 2h30m | now    resume at a time you name (also ISO-8601)
#     add:  [critical|normal|low]  [--session <n|id|latest|new>]
#           [--prompt "<text>"]  [--workspace <path>]
#
# Check & control:
#   status              this project's task (the default command)
#   output [--workspace <path>]   show the resume's live/last output
#   sessions            list this project's conversations (pick which resumes)
#   list                every tracked project
#   watch | log [n]     follow / show the daemon log
#   cancel              stop the scheduled resume
#   doctor              environment health check
#
# Setup & maintenance:
#   setup-statusline | remove-statusline   opt-in: capture the exact reset time
#   update  |  uninstall [--yes]  |  version
set -u

ORIG0="$0"
SELF="$0"
while [ -L "$SELF" ]; do
  DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in
    /*) ;;
    *) SELF="$DIR/$SELF" ;;
  esac
done
SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT="$(cd "$SELF_DIR/.." && pwd)"

SCRIPTS_DIR="${CLAUDE_STANDBY_PLUGIN_DIR:-$ROOT/plugin}/scripts"
if [ ! -f "$SCRIPTS_DIR/lib.sh" ]; then
  echo "claude-standby: plugin scripts not found at $SCRIPTS_DIR"
  echo "Set CLAUDE_STANDBY_PLUGIN_DIR to the plugin directory."
  exit 1
fi

LOG_FILE="${CLAUDE_STANDBY_LOG_DIR:-$HOME/.claude/auto-resume/logs}/plugin.log"
INSTALL_URL="https://raw.githubusercontent.com/0xsaju/claude-standby/main/install.sh"
# Same default layout doctor/daemon.sh use (via lib.sh's AR_HOME) — computed
# here without a full lib.sh source so `uninstall` can find daemon pidfiles
# even though it doesn't otherwise need the library (F18).
AR_HOME_DIR="$(dirname "${CLAUDE_STANDBY_STATE:-$HOME/.claude/auto-resume/state.json}")"

# Stop every ownership-plausible daemon under $1/daemons/*.pid before we let
# the caller remove files out from under it (F18). Ownership check: the pid
# must be a live process whose command line actually mentions daemon.sh —
# never signal a PID that was merely reused for something unrelated.
stop_workspace_daemons() {
  local dir="$1/daemons" p pid cmd stopped=0 failed=0 tries
  [ -d "$dir" ] || return 0
  for p in "$dir"/*.pid; do
    [ -e "$p" ] || break
    pid="$(cat "$p" 2>/dev/null | tr -dc '0-9')"
    if [ -z "$pid" ] || [ "$pid" -le 1 ] 2>/dev/null; then
      rm -f "$p"
      continue
    fi
    if kill -0 "$pid" 2>/dev/null; then
      cmd="$(ps -p "$pid" -o command= 2>/dev/null || ps -p "$pid" -o args= 2>/dev/null)"
      case "$cmd" in
        *daemon.sh*)
          kill "$pid" 2>/dev/null
          tries=0
          while kill -0 "$pid" 2>/dev/null && [ "$tries" -lt 5 ]; do
            sleep 1
            tries=$((tries + 1))
          done
          if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null
            sleep 1
          fi
          if kill -0 "$pid" 2>/dev/null; then
            echo "warning: could not stop daemon pid $pid ($(basename "$p" .pid))" >&2
            failed=$((failed + 1))
          else
            stopped=$((stopped + 1))
          fi
          ;;
      esac
    fi
    rm -f "$p"
  done
  [ "$stopped" -gt 0 ] && echo "Stopped $stopped daemon(s)."
  [ "$failed" -eq 0 ]
}

usage() {
  # Print the header comment block (from line 4) up to the first non-comment.
  awk 'NR > 3 { if ($0 !~ /^#/) exit; sub(/^# ?/, ""); print }' "$SELF"
}

car_version() {
  head -1 "$ROOT/VERSION" 2>/dev/null | tr -d '[:space:]'
}

car_gitrev() {
  git -C "$ROOT" rev-parse --short HEAD 2>/dev/null
}

# The old plugin packaging (removed 2026-07-19, D33) lives in Claude Code's
# own plugin store — deleting our files can't remove it. True only for
# pre-removal users who still have a trace of it.
car_had_legacy_plugin() {
  P="${CLAUDE_PLUGINS_DIR:-$HOME/.claude/plugins}"
  grep -qs "claude-standby" "$P/config.json" 2>/dev/null && return 0
  grep -qs "claude-auto-resume@auto-resume" "${CLAUDE_SETTINGS_FILE:-$HOME/.claude/settings.json}" 2>/dev/null && return 0
  [ -n "$(find "$P" -maxdepth 3 -name 'claude-standby*' -print 2>/dev/null | head -1)" ]
}

CMD="${1:-status}"
if [ $# -gt 0 ]; then shift; fi

case "$CMD" in
  status)
    exec bash "$SCRIPTS_DIR/task-status.sh" ;;

  start)
    exec bash "$SCRIPTS_DIR/task-start.sh" "$@" ;;

  resume-at|resume)
    exec bash "$SCRIPTS_DIR/task-resume-at.sh" "$@" ;;

  sessions)
    exec bash "$SCRIPTS_DIR/task-sessions.sh" "$@" ;;

  output)
    # Show the resume's streamed output for a workspace (cwd, or --workspace
    # <path>). The daemon streams each resume to this file live (D44); when it
    # is absent, fall back to the captured tail in state.
    # shellcheck disable=SC1091
    . "$SCRIPTS_DIR/lib.sh" || exit 1
    OWS="$(pwd)"
    # Accept the same --workspace forms resume-at does (spaced, glued, -w).
    case "${1:-}" in
      --workspace|-w) [ -n "${2:-}" ] && OWS="$2" ;;
      --workspace=*)  OWS="${1#--workspace=}" ;;
    esac
    # Canonicalize (trailing slash / relative path) so we derive the SAME key
    # the daemon wrote the live file and state under.
    [ -d "$OWS" ] && OWS="$(cd "$OWS" 2>/dev/null && pwd)"
    OFILE="$(ar_resume_live_file "$OWS")"
    if [ -s "$OFILE" ]; then
      cat "$OFILE"
    else
      TAIL="$(ar_task_get "$OWS" last_output_tail)"
      if [ -n "$TAIL" ]; then
        printf '%s\n' "$TAIL"
      else
        echo "No resume output yet for $OWS."
      fi
    fi
    exit 0 ;;

  cancel)
    exec bash "$SCRIPTS_DIR/task-cancel.sh" ;;

  list|ls)
    # shellcheck disable=SC1091
    . "$SCRIPTS_DIR/lib.sh" || exit 1
    FOUND=0
    while IFS= read -r ws; do
      [ -n "$ws" ] || continue
      if [ "$FOUND" -eq 0 ]; then
        printf '%-10s %-9s %s\n' "STATUS" "TIER" "WORKSPACE"
      fi
      FOUND=1
      printf '%-10s %-9s %s\n' "$(ar_task_get "$ws" status)" "$(ar_task_get "$ws" importance)" "$ws"
    done <<EOF
$(ar_task_list)
EOF
    [ "$FOUND" -eq 1 ] || echo "No tracked tasks."
    exit 0 ;;

  log)
    if [ -f "$LOG_FILE" ]; then
      exec tail -n "${1:-40}" "$LOG_FILE"
    fi
    echo "No log yet at $LOG_FILE"
    exit 0 ;;

  watch)
    if ! mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null; then
      echo "claude-standby: cannot create log directory $(dirname "$LOG_FILE")" >&2
      exit 1
    fi
    if ! touch "$LOG_FILE" 2>/dev/null; then
      echo "claude-standby: cannot create log file $LOG_FILE" >&2
      exit 1
    fi
    exec tail -f "$LOG_FILE" ;;

  doctor)
    # shellcheck disable=SC1091
    . "$SCRIPTS_DIR/lib.sh" || { echo "broken install: cannot load lib.sh"; exit 1; }
    RC=0
    REV="$(car_gitrev)"
    echo "claude-standby $(car_version)${REV:+ ($REV)}"
    printf '  %-8s %-5s %s\n' "install" "ok" "$ROOT"
    CB="${CLAUDE_STANDBY_CLAUDE_BIN:-${AR_CFG_CLAUDE_BIN:-claude}}"
    if command -v "$CB" >/dev/null 2>&1; then
      printf '  %-8s %-5s %s\n' "claude" "ok" "$(command -v "$CB")"
    else
      printf '  %-8s %-5s %s\n' "claude" "MISS" "'$CB' not found — resumes cannot run"
      RC=1
    fi
    printf '  %-8s %-5s %s\n' "json" "ok" "engine: $(ar_json_engine)"
    # F22: validate the state file's health, don't just check existence — a
    # corrupt or unsupported-schema file must report BAD and exit nonzero, not
    # a cheerful "ok".
    SH="$(ar_state_health 2>/dev/null)"
    case "$SH" in
      ok)      N="$(ar_task_list | grep -c . || true)"
               printf '  %-8s %-5s %s\n' "state" "ok" "$AR_STATE_FILE ($N task(s))" ;;
      missing) printf '  %-8s %-5s %s\n' "state" "ok" "none yet (will be $AR_STATE_FILE)" ;;
      corrupt) printf '  %-8s %-5s %s\n' "state" "BAD" "$AR_STATE_FILE is corrupt (unparseable) — fix or remove it"; RC=1 ;;
      unsupported) printf '  %-8s %-5s %s\n' "state" "BAD" "$AR_STATE_FILE is an unsupported schema version — upgrade claude-standby"; RC=1 ;;
      *)       printf '  %-8s %-5s %s\n' "state" "BAD" "$AR_STATE_FILE health could not be determined"; RC=1 ;;
    esac
    RUNNING=0; STALE=0
    for p in "$AR_HOME/daemons"/*.pid; do
      [ -e "$p" ] || break
      if kill -0 "$(cat "$p" 2>/dev/null)" 2>/dev/null; then
        RUNNING=$((RUNNING + 1))
      else
        STALE=$((STALE + 1))
      fi
    done
    printf '  %-8s %-5s %s\n' "daemons" "ok" "$RUNNING running, $STALE stale"
    if ar_rate_usable; then
      RSRC="$(ar_rate_file)"; RESET_E="$(ar_rate_get resets_at)"; USED_P="$(ar_rate_get used_percentage)"
      printf '  %-8s %-5s %s\n' "reset" "ok" "$(ar_epoch_to_iso "$RESET_E") (${USED_P:-?}% used) — via $(basename "$RSRC")"
    else
      printf '  %-8s %-5s %s\n' "reset" "--" "no local reset time; auto-detect will probe (see: setup-statusline, or AR_CFG_RATE_SOURCE)"
    fi
    if command -v osascript >/dev/null 2>&1; then
      printf '  %-8s %-5s %s\n' "notify" "ok" "osascript"
    elif command -v notify-send >/dev/null 2>&1; then
      printf '  %-8s %-5s %s\n' "notify" "ok" "notify-send"
    else
      printf '  %-8s %-5s %s\n' "notify" "ok" "log-only (no desktop notifier found)"
    fi
    exit "$RC" ;;

  setup-statusline)
    exec bash "$SCRIPTS_DIR/setup-statusline.sh" install ;;

  remove-statusline)
    exec bash "$SCRIPTS_DIR/setup-statusline.sh" remove ;;

  update)
    # Updates are download-validate-swap via the installer (D36) — never
    # `git pull` into the live tree. A git checkout outside the managed
    # install dir is a development copy: hands off.
    MANAGED_DIR="${CAR_INSTALL_DIR:-$HOME/.claude-standby}"
    if [ "$ROOT" != "$MANAGED_DIR" ] && [ -d "$ROOT/.git" ]; then
      echo "This is a development checkout — update it with git:"
      echo "  git -C \"$ROOT\" pull"
      exit 1
    fi
    if [ ! -f "$ROOT/install.sh" ]; then
      echo "Installer script missing from this install. Re-run the installer to update:"
      echo "  curl -fsSL $INSTALL_URL | bash"
      exit 1
    fi
    exec env CAR_INSTALL_DIR="$ROOT" bash "$ROOT/install.sh" --update ;;

  uninstall)
    # A git checkout OUTSIDE the managed dir is a development copy — refuse
    # (same signal `update` uses). Presence of .git is the test, not
    # dirtiness: a *clean* dev checkout must be protected too. The managed
    # install is a plain tree (D36) so this never blocks a real uninstall,
    # and a legacy git-based managed install still uninstalls because
    # ROOT == MANAGED_DIR.
    MANAGED_DIR="${CAR_INSTALL_DIR:-$HOME/.claude-standby}"
    if [ -d "$ROOT/.git" ] && [ "$ROOT" != "$MANAGED_DIR" ]; then
      echo "Refusing: $ROOT is a git checkout — this looks like a development checkout."
      echo "If it really is an installed copy, remove it with:"
      echo "  curl -fsSL $INSTALL_URL | bash -s -- --uninstall"
      exit 1
    fi
    [ -n "$(git -C "$ROOT" status --porcelain 2>/dev/null)" ] \
      && echo "note: $ROOT has local changes — they will be removed with it."
    if [ "${1:-}" != "--yes" ]; then
      printf 'Remove %s and its CLI link? [y/N] ' "$ROOT"
      if ! read -r ANS </dev/tty 2>/dev/null; then
        echo ""
        echo "No terminal for confirmation — run: claude-standby uninstall --yes"
        exit 1
      fi
      case "$ANS" in y|Y|yes|YES) ;; *) echo "Aborted."; exit 0 ;; esac
    fi
    if ! stop_workspace_daemons "$AR_HOME_DIR"; then
      echo "Refusing to remove $ROOT while a daemon is still running — retry once it stops, or kill it manually." >&2
      exit 1
    fi
    SENSOR_OUT="$(bash "$SCRIPTS_DIR/setup-statusline.sh" remove 2>&1)"
    SENSOR_RC=$?
    printf '%s\n' "$SENSOR_OUT" | grep -v "nothing to remove" || true
    if [ "$SENSOR_RC" -ne 0 ]; then
      echo "Could not remove the status-line sensor — aborting uninstall so settings.json isn't left referencing a deleted script." >&2
      exit 1
    fi
    [ -L "$ORIG0" ] && rm -f "$ORIG0"
    FOUND_LINK="$(command -v claude-standby 2>/dev/null || true)"
    if [ -n "$FOUND_LINK" ] && [ -L "$FOUND_LINK" ]; then
      case "$(readlink "$FOUND_LINK")" in
        "$ROOT"*) rm -f "$FOUND_LINK" ;;
      esac
    fi
    rm -rf "$ROOT"
    echo "Removed."
    echo "Kept your task state and logs. To remove them too:"
    echo "  rm -rf ~/.claude/auto-resume"
    if car_had_legacy_plugin; then
      echo "You still have the old Claude Code plugin. Remove it inside a session (it no longer ships):"
      echo "  /plugin uninstall claude-auto-resume@auto-resume"
    fi
    exit 0 ;;

  version|--version|-V)
    REV="$(car_gitrev)"
    echo "claude-standby $(car_version)${REV:+ ($REV)}"
    exit 0 ;;

  help|-h|--help)
    usage
    exit 0 ;;

  *)
    echo "claude-standby: unknown command '$CMD'"
    echo
    usage
    exit 1 ;;
esac
